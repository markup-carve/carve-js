{
  "name": "@markup-carve/carve",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reference TypeScript implementation of the Carve markup language",
  "license": "MIT",
  "author": "Mark Scherer",
  "homepage": "https://markup-carve.github.io/carve/",
  "repository": {
    "type": "git",
    "url": "https://github.com/markup-carve/carve-js.git"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
